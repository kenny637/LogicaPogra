def evento_aleatorio(jogador):
    evento = random.randint(1, 32)
    if evento == 1:
        jogador.vida += int(0.10 * jogador.vida_max)
        jogador.estamina += int(0.20 * jogador.estamina_max)
    elif evento == 2:
        jogador.vida -= int(0.05 * jogador.vida_max)
        jogador.estamina -= int(0.10 * jogador.estamina_max)
    elif evento == 3:
        jogador.vida += int(0.30 * jogador.vida_max)
        jogador.mana += int(0.30 * jogador.mana_max)
    elif evento == 4:
        jogador.vida += int(0.15 * jogador.vida_max)
        jogador.estamina += int(0.20 * jogador.estamina_max)
    elif evento == 5:
        jogador.pocao_cura += random.randint(1,2)
        jogador.pocao_mana += random.randint(1,2)
    elif evento == 6:
        jogador.vida -= int(0.10 * jogador.vida_max)
    elif evento == 8:
        jogador.estamina -= int(0.10 * jogador.estamina_max)
    elif evento == 10:
        jogador.vida -= int(0.15 * jogador.vida_max)
    # outros eventos podem ser mantidos, mas omitidos por brevidade
    return jogador

