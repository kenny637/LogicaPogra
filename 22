class NeuralDecisionMaker:
    def __init__(self, input_dim, output_dim, learning_rate=0.01, model_path=None):
        self.input_dim = input_dim
        self.output_dim = output_dim
        self.lr = learning_rate
        self.weights = np.random.randn(input_dim, output_dim) * 0.01
        self.bias = np.zeros(output_dim)
        self.states = []
        self.actions = []
        self.rewards = []
        self.model_path = model_path
        if model_path and os.path.exists(model_path):
            self.load()

    def _softmax(self, x):
        e_x = np.exp(x - np.max(x))
        return e_x / e_x.sum()

    def choose_action(self, state):
        state = np.array(state).flatten()
        logits = np.dot(state, self.weights) + self.bias
        probs = self._softmax(logits)
        action = np.random.choice(range(self.output_dim), p=probs)
        self.states.append(state)
        self.actions.append(action)
        return action

    def learn(self, reward):
        self.rewards.append(reward)

    def end_episode(self):
        if not self.states:
            return
        gamma = 0.99
        returns = []
        R = 0
        for r in reversed(self.rewards):
            R = r + gamma * R
            returns.insert(0, R)
        returns = np.array(returns)
        if len(returns) > 1 and np.std(returns) > 1e-8:
            returns = (returns - np.mean(returns)) / np.std(returns)
        for state, action, G in zip(self.states, self.actions, returns):
            logits = np.dot(state, self.weights) + self.bias
            probs = self._softmax(logits)
            grad = -probs
            grad[action] += 1.0
            grad = grad * G
            self.weights -= self.lr * np.outer(state, grad)
            self.bias -= self.lr * grad
        self.states.clear()
        self.actions.clear()
        self.rewards.clear()

    def save(self):
        if self.model_path:
            with open(self.model_path, 'wb') as f:
                pickle.dump((self.weights, self.bias), f)
            if VERBOSE:
                print(f"Modelo salvo em {self.model_path}")

    def load(self):
        with open(self.model_path, 'rb') as f:
            self.weights, self.bias = pickle.load(f)
        if VERBOSE:
            print(f"Modelo carregado de {self.model_path}")

