def upgrade_nivel(jogador, neural_upgrade, db):
    if VERBOSE:
        print(f"Subiu para nível {jogador.nivel}!")
        print(f"Pontos de habilidade: {jogador.pontos_abilidades}")
    state = [
        jogador.dano_base / 100,
        jogador.dano_magia / 100,
        jogador.escudo_base / 100,
        jogador.vida_max / 500,
        jogador.mana_max / 200,
        jogador.estamina_max / 400,
        jogador.eficiencia_cura / 100,
        jogador.eficiencia_mana / 100
    ]
    while jogador.pontos_abilidades > 0:
        acao = neural_upgrade.choose_action(state)
        atributo = ""
        valor_anterior = 0
        valor_novo = 0
        if acao == 0:
            atributo = "dano_base"
            valor_anterior = jogador.dano_base
            jogador.dano_base += 5
            valor_novo = jogador.dano_base
        elif acao == 1:
            atributo = "dano_magia"
            valor_anterior = jogador.dano_magia
            jogador.dano_magia += 7
            valor_novo = jogador.dano_magia
        elif acao == 2:
            atributo = "escudo_base"
            valor_anterior = jogador.escudo_base
            jogador.escudo_base += 5
            valor_novo = jogador.escudo_base
        elif acao == 3:
            atributo = "mana_max"
            valor_anterior = jogador.mana_max
            jogador.mana_max += 30
            jogador.mana += 30
            valor_novo = jogador.mana_max
        elif acao == 4:
            atributo = "vida_max"
            valor_anterior = jogador.vida_max
            jogador.vida_max += 30
            jogador.vida += 30
            valor_novo = jogador.vida_max
        elif acao == 5:
            atributo = "estamina_max"
            valor_anterior = jogador.estamina_max
            jogador.estamina_max += 40
            jogador.estamina += 40
            valor_novo = jogador.estamina_max
        elif acao == 6:
            atributo = "eficiencia_cura"
            valor_anterior = jogador.eficiencia_cura
            jogador.eficiencia_cura += 2
            valor_novo = jogador.eficiencia_cura
        elif acao == 7:
            atributo = "eficiencia_mana"
            valor_anterior = jogador.eficiencia_mana
            jogador.eficiencia_mana += 2
            valor_novo = jogador.eficiencia_mana
        else:
            continue
        jogador.pontos_abilidades -= 1
        db.log_upgrade(jogador.nivel, atributo, valor_anterior, valor_novo)
        if VERBOSE:
            print(f"Upgrade: {atributo} {valor_anterior} -> {valor_novo}")
        # Atualiza estado após cada upgrade
        state = [
            jogador.dano_base / 100,
            jogador.dano_magia / 100,
            jogador.escudo_base / 100,
            jogador.vida_max / 500,
            jogador.mana_max / 200,
            jogador.estamina_max / 400,
            jogador.eficiencia_cura / 100,
            jogador.eficiencia_mana / 100
        ]
        neural_upgrade.learn(1.0)
    neural_upgrade.end_episode()

