class Jogador:
    def __init__(self):
        self.nome = "Herói"
        self.vida_max = 100
        self.vida = self.vida_max
        self.mana_max = 50
        self.mana = self.mana_max
        self.estamina_max = 150
        self.estamina = self.estamina_max

        self.dano_base = 12
        self.escudo_base = 8
        self.dano_magia = 20
        self.eficiencia_cura = 10
        self.eficiencia_mana = 10

        self.perda_mana_base = 15
        self.perda_estamina_base = 3

        self.nivel = 1
        self.xp_atual = 0
        self.xp_proximo = 20
        self.pontos_abilidades = 0

        self.pocao_cura = 5
        self.pocao_mana = 5
        self.pocao_adrenalina = 1
        self.pocao_agilidade = 1
        self.moedas = {'bronze': 0, 'prata': 0, 'ouro': 0}

        self.ingredientes = {
            'Raízes Revigorantes': 0,
            'Cogumelo Brilhante': 0,
            'Erva-de-São-João': 0,
            'Rhodiola Rosea': 0
        }

        self.espada_aprimorada = False
        self.espada_forjada = False
        self.runa_adquirida = False
        self.escudo_criado = False
        self.cajado_criado = False
        self.manto_criado = False
        self.joia_criada = False

        self.dano_bonus = 0
        self.escudo_bonus = 0
        self.adrenalina_bonus = 0
        self.agilidade_bonus = 0
        self.critico = 0.4
        self.ctco = 0

        self.abilidade_100 = False

        self.buffs_ativos = {
            'dano': False,
            'escudo': False,
            'adrenalina': False,
            'agilidade': False
        }

        self.defendendo = False
        self.esquivando = False

    def aplicar_buffs(self):
        if self.dano_bonus > 0 and not self.buffs_ativos['dano']:
            self.dano_base = int(self.dano_base * 1.10)
            self.buffs_ativos['dano'] = True
        elif self.dano_bonus == 0 and self.buffs_ativos['dano']:
            self.dano_base = int(self.dano_base / 1.10)
            self.buffs_ativos['dano'] = False

        if self.escudo_bonus > 0 and not self.buffs_ativos['escudo']:
            self.escudo_base = int(self.escudo_base * 1.10)
            self.buffs_ativos['escudo'] = True
        elif self.escudo_bonus == 0 and self.buffs_ativos['escudo']:
            self.escudo_base = int(self.escudo_base / 1.10)
            self.buffs_ativos['escudo'] = False

        if self.adrenalina_bonus > 0 and not self.buffs_ativos['adrenalina']:
            self.perda_estamina_base = int(self.perda_estamina_base * 0.66)
            self.perda_mana_base = int(self.perda_mana_base * 0.33)
            self.buffs_ativos['adrenalina'] = True
        elif self.adrenalina_bonus == 0 and self.buffs_ativos['adrenalina']:
            self.perda_estamina_base = 3
            self.perda_mana_base = 15
            self.buffs_ativos['adrenalina'] = False

        if self.agilidade_bonus > 0:
            self.agilidade_bonus -= 1

        if self.dano_bonus > 0:
            self.dano_bonus -= 1
        if self.escudo_bonus > 0:
            self.escudo_bonus -= 1
        if self.adrenalina_bonus > 0:
            self.adrenalina_bonus -= 1

    def gastar_estamina(self, custo):
        if self.estamina >= custo:
            self.estamina -= custo
            return True
        return False

    def curar(self, valor):
        self.vida = min(self.vida_max, self.vida + valor)

    def recuperar_mana(self, valor):
        self.mana = min(self.mana_max, self.mana + valor)

    def aplicar_dano(self, dano):
        self.vida = max(0, self.vida - dano)


class Inimigo:
    def __init__(self, nome, vida_max, nivel, xp_min, xp_max):
        self.nome = nome
        self.vida_max = vida_max
        self.vida = vida_max
        self.nivel = nivel
        self.xp_min = xp_min
        self.xp_max = xp_max

        self.dano_base = 12
        self.escudo_base = 8
        self.dano_magia = 20
        self.eficiencia_cura = 15
        self.eficiencia_mana = 15
        self.mana_max = 50
        self.mana = self.mana_max
        self.estamina_max = 100
        self.estamina = self.estamina_max
        self.perda_mana_base = 15
        self.perda_estamina_base = 3

        for _ in range(nivel):
            self.escudo_base += 4
            self.dano_base += 4
            self.dano_magia += 5
            self.eficiencia_cura += 2
            self.eficiencia_mana += 2
            self.mana_max += 30
            self.estamina_max += 40
        self.mana = self.mana_max
        self.estamina = self.estamina_max

        self.estilo = random.randint(1, 4)
        self.padrao_acoes = []
        self.jogador_leitura = [0]*6

        self.defendendo = False
        self.esquivando = False

    def escolher_acao_ia(self, ultima_acao_jogador):
        self.padrao_acoes.append(ultima_acao_jogador)
        if len(self.padrao_acoes) > 10:
            self.padrao_acoes.pop(0)

        if self.estilo == 1:
            ataque, defesa, esquiva, magia, cura, mana = 20, 30, 25, 15, 5, 5
        elif self.estilo == 2:
            ataque, defesa, esquiva, magia, cura, mana = 15, 10, 10, 30, 25, 10
        elif self.estilo == 3:
            ataque, defesa, esquiva, magia, cura, mana = 35, 15, 10, 30, 5, 5
        else:
            ataque, defesa, esquiva, magia, cura, mana = 25, 20, 15, 20, 10, 10

        if self.vida <= self.vida_max * 0.2:
            ataque, magia, cura = 40, 30, 30
            defesa, esquiva, mana = 0, 0, 0
        elif self.vida <= self.vida_max * 0.5:
            ataque, magia, cura = 35, 30, 20
            defesa, esquiva, mana = 10, 5, 0
        elif self.vida <= self.vida_max * 0.7:
            ataque, magia, cura = 30, 25, 15
            defesa, esquiva, mana = 15, 10, 5

        soma = ataque + defesa + esquiva + magia + cura + mana
        r = random.randint(1, soma)
        if r <= ataque:
            return 1
        elif r <= ataque + defesa:
            return 2
        elif r <= ataque + defesa + esquiva:
            return 3
        elif r <= ataque + defesa + esquiva + magia:
            return 4
        elif r <= ataque + defesa + esquiva + magia + cura:
            return 5
        else:
            return 6

    def gastar_estamina(self, custo):
        if self.estamina >= custo:
            self.estamina -= custo
            return True
        return False

    def gastar_mana(self, custo):
        if self.mana >= custo:
            self.mana -= custo
            return True
        return False

    def curar(self, valor):
        self.vida = min(self.vida_max, self.vida + valor)

    def recuperar_mana(self, valor):
        self.mana = min(self.mana_max, self.mana + valor)

    def aplicar_dano(self, dano):
        self.vida = max(0, self.vida - dano)

