class Database:
    def __init__(self, db_path="rpg_ia.db"):
        self.conn = sqlite3.connect(db_path)
        self.cursor = self.conn.cursor()
        self._create_tables()

    def _create_tables(self):
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS combate_acoes (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                timestamp TEXT,
                turno INTEGER,
                estado_vida_inimigo REAL,
                estado_vida_jogador REAL,
                estado_mana_jogador REAL,
                estado_estamina_jogador REAL,
                ultima_acao REAL,
                acao INTEGER,
                recompensa REAL,
                resultado_combate TEXT
            )
        ''')
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS combates (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                timestamp TEXT,
                inimigo TEXT,
                nivel_inimigo INTEGER,
                nivel_jogador INTEGER,
                vitoria BOOLEAN,
                turnos INTEGER,
                xp_ganho INTEGER,
                vida_final_jogador INTEGER,
                mana_final_jogador INTEGER
            )
        ''')
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS exploracao_acoes (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                timestamp TEXT,
                acao INTEGER,
                estado_vida REAL,
                estado_mana REAL,
                estado_estamina REAL,
                estado_moedas REAL,
                estado_nivel REAL,
                recompensa REAL,
                encontrou_inimigo BOOLEAN
            )
        ''')
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS compras (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                timestamp TEXT,
                loja TEXT,
                item TEXT,
                custo INTEGER,
                moeda TEXT,
                sucesso BOOLEAN,
                recompensa REAL
            )
        ''')
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS upgrades (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                timestamp TEXT,
                nivel INTEGER,
                atributo TEXT,
                valor_anterior REAL,
                valor_novo REAL
            )
        ''')
        self.conn.commit()

    def log_combate_acao(self, turno, estado, acao, recompensa, resultado_combate):
        self.cursor.execute('''
            INSERT INTO combate_acoes
            (timestamp, turno, estado_vida_inimigo, estado_vida_jogador, estado_mana_jogador,
             estado_estamina_jogador, ultima_acao, acao, recompensa, resultado_combate)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (datetime.now().isoformat(), turno, estado[0], estado[1], estado[2], estado[3], estado[4],
              acao, recompensa, resultado_combate))
        self.conn.commit()

    def log_combate_resultado(self, inimigo, nivel_inimigo, nivel_jogador, vitoria, turnos, xp_ganho, vida_final, mana_final):
        self.cursor.execute('''
            INSERT INTO combates
            (timestamp, inimigo, nivel_inimigo, nivel_jogador, vitoria, turnos, xp_ganho, vida_final_jogador, mana_final_jogador)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (datetime.now().isoformat(), inimigo, nivel_inimigo, nivel_jogador, vitoria, turnos, xp_ganho, vida_final, mana_final))
        self.conn.commit()

    def log_exploracao(self, acao, estado, recompensa, encontrou_inimigo):
        self.cursor.execute('''
            INSERT INTO exploracao_acoes
            (timestamp, acao, estado_vida, estado_mana, estado_estamina, estado_moedas, estado_nivel, recompensa, encontrou_inimigo)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (datetime.now().isoformat(), acao, estado[0], estado[1], estado[2], estado[3], estado[4], recompensa, encontrou_inimigo))
        self.conn.commit()

    def log_compra(self, loja, item, custo, moeda, sucesso, recompensa):
        self.cursor.execute('''
            INSERT INTO compras
            (timestamp, loja, item, custo, moeda, sucesso, recompensa)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        ''', (datetime.now().isoformat(), loja, item, custo, moeda, sucesso, recompensa))
        self.conn.commit()

    def log_upgrade(self, nivel, atributo, valor_anterior, valor_novo):
        self.cursor.execute('''
            INSERT INTO upgrades
            (timestamp, nivel, atributo, valor_anterior, valor_novo)
            VALUES (?, ?, ?, ?, ?)
        ''', (datetime.now().isoformat(), nivel, atributo, valor_anterior, valor_novo))
        self.conn.commit()

    def close(self):
        self.conn.close()

