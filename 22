def resetar_jogador():
    """Cria um novo jogador com todos os atributos iniciais."""
    return Jogador()

def treinar():
    print("Iniciando treinamento da IA...")
    print(f"Total de partidas: {MAX_PARTIDAS}")
    print(f"Modo silencioso: {not VERBOSE}")
    db = Database()
    # Carrega ou cria redes
    neural_combate = NeuralDecisionMaker(input_dim=5, output_dim=6, learning_rate=0.01, model_path="neural_combate.pkl")
    neural_exploracao = NeuralDecisionMaker(input_dim=5, output_dim=3, learning_rate=0.01, model_path="neural_exploracao.pkl")
    neural_cidade = NeuralDecisionMaker(input_dim=5, output_dim=10, learning_rate=0.01, model_path="neural_cidade.pkl")
    neural_upgrade = NeuralDecisionMaker(input_dim=8, output_dim=8, learning_rate=0.01, model_path="neural_upgrade.pkl")

    partidas = 0
    while partidas < MAX_PARTIDAS:
        partidas += 1
        if partidas % 100 == 0:
            print(f"Partida {partidas}/{MAX_PARTIDAS} concluída.")
        # Reinicia jogador
        jogador = resetar_jogador()
        exploracao = Exploracao(jogador, neural_exploracao, neural_cidade, db)
        indice_capitulo = 0
        capitulo_atual = capitulos[indice_capitulo]

        # Loop da partida
        while True:
            if not exploracao.encontrado:
                encontrado = exploracao.andar()
                if encontrado:
                    nomes = list(capitulo_atual.keys())
                    if not nomes:
                        indice_capitulo += 1
                        if indice_capitulo < len(capitulos):
                            capitulo_atual = capitulos[indice_capitulo]
                            continue
                        else:
                            # Terminou todos os capítulos – vitória
                            if VERBOSE: print("Jogador venceu o jogo!")
                            break
                    nome_inimigo = random.choice(nomes)
                    dados = capitulo_atual[nome_inimigo]
                    nivel_i = random.randint(max(1, jogador.nivel-3), jogador.nivel+3)
                    inimigo = Inimigo(nome_inimigo, dados['vida'], nivel_i, dados['xp_min'], dados['xp_max'])
                    combate = Combate(jogador, inimigo, neural_combate, db)
                    venceu = combate.combater()
                    if venceu:
                        xp_ganho = random.randint(inimigo.xp_min, inimigo.xp_max)
                        jogador.xp_atual += xp_ganho
                        db.log_combate_resultado(
                            nome_inimigo, nivel_i, jogador.nivel, True,
                            combate.turno, xp_ganho, jogador.vida, jogador.mana
                        )
                        if jogador.xp_atual >= jogador.xp_proximo:
                            jogador.nivel += 1
                            jogador.xp_atual -= jogador.xp_proximo
                            jogador.xp_proximo = int(jogador.xp_proximo * 1.2)
                            jogador.pontos_abilidades += 4
                            upgrade_nivel(jogador, neural_upgrade, db)
                    else:
                        db.log_combate_resultado(
                            nome_inimigo, nivel_i, jogador.nivel, False,
                            combate.turno, 0, jogador.vida, jogador.mana
                        )
                        break  # Fim da partida (morreu)
                    exploracao.encontrado = False
            else:
                # Não deveria acontecer, mas por segurança
                exploracao.encontrado = False
        # Fim da partida (morte ou vitória final)
        # Salva redes periodicamente
        if partidas % SALVAR_INTERVALO == 0:
            neural_combate.save()
            neural_exploracao.save()
            neural_cidade.save()
            neural_upgrade.save()
            # Opcional: compactar banco
            # db.conn.commit()
    # Fim do treinamento
    print("Treinamento concluído!")
    neural_combate.save()
    neural_exploracao.save()
    neural_cidade.save()
    neural_upgrade.save()
    db.close()

