class Exploracao:
    def __init__(self, jogador, neural_exploracao, neural_cidade, db):
        self.jogador = jogador
        self.neural = neural_exploracao
        self.neural_cidade = neural_cidade
        self.db = db
        self.encontrado = False
        self.cavalo = False
        self.energia = 0.05
        self.abilidade_100 = False

    def andar(self):
        state = [
            self.jogador.vida / self.jogador.vida_max,
            self.jogador.mana / self.jogador.mana_max,
            self.jogador.estamina / self.jogador.estamina_max,
            min(self.jogador.moedas['ouro'] / 100, 1.0),
            self.jogador.nivel / 50
        ]
        acao = self.neural.choose_action(state)  # 0=andar, 1=descansar, 2=vila

        recompensa = 0
        encontrou_inimigo = False

        if acao == 0:  # Andar
            custo = int(self.energia * self.jogador.estamina_max)
            if self.jogador.estamina >= custo:
                self.jogador.estamina -= custo
                if random.random() < 0.6:  # Aumentado para 60% de chance de combate
                    self.encontrado = True
                    encontrou_inimigo = True
                    recompensa = 1.0
                else:
                    evento_aleatorio(self.jogador)
                    recompensa = 0.5
                if self.jogador.estamina < self.jogador.estamina_max * 0.2:
                    recompensa -= 0.5
            else:
                recompensa = -1.0
        elif acao == 1:  # Descansar
            recuperacao = int(self.jogador.estamina_max * 0.10)
            self.jogador.estamina = min(self.jogador.estamina_max, self.jogador.estamina + recuperacao)
            if self.jogador.estamina == self.jogador.estamina_max:
                recompensa = -0.5
            else:
                recompensa = 0.5
        else:  # Ir à vila
            recompensa = self.cidade()

        self.db.log_exploracao(acao, state, recompensa, encontrou_inimigo)
        self.neural.learn(recompensa)
        self.neural.end_episode()
        return self.encontrado

    def cidade(self):
        # Entrada na cidade (a IA pode decidir qual loja visitar)
        state_loja = [
            self.jogador.moedas['ouro'] / 100,
            self.jogador.moedas['prata'] / 100,
            self.jogador.moedas['bronze'] / 100,
            self.jogador.nivel / 50,
            self.jogador.vida / self.jogador.vida_max
        ]
        loja_idx = self.neural_cidade.choose_action(state_loja)
        if loja_idx >= 4:
            loja = 4  # Sair
        else:
            loja = loja_idx + 1

        recompensa_total = 0
        if loja == 1:
            recompensa_total = self.loja_ferreiro()
        elif loja == 2:
            recompensa_total = self.loja_feiticeiro()
        elif loja == 3:
            recompensa_total = self.loja_ervas()
        else:
            pass  # Sair

        self.neural_cidade.end_episode()
        return recompensa_total

    def loja_ferreiro(self):
        itens = [
            ("Forjar Espada (+5 dano)", 25, "prata", "espada_forjada", lambda: setattr(self.jogador, 'dano_base', self.jogador.dano_base + 5)),
            ("Melhorar Armadura (+1 defesa)", 30, "prata", None, lambda: setattr(self.jogador, 'escudo_base', self.jogador.escudo_base + 1)),
            ("Runa de Safira (+10 defesa)", 20, "ouro", "runa_adquirida", lambda: setattr(self.jogador, 'escudo_base', self.jogador.escudo_base + 10)),
            ("Criar Escudo (+5 defesa)", 5, "ouro", "escudo_criado", lambda: setattr(self.jogador, 'escudo_base', self.jogador.escudo_base + 5)),
            ("Afiar Armas (bônus temporário)", 15, "prata", None, lambda: setattr(self.jogador, 'dano_bonus', self.jogador.dano_bonus + 30)),
            ("Melhorar Espada (+1 dano)", 10, "prata", None, lambda: setattr(self.jogador, 'dano_base', self.jogador.dano_base + 1)),
            ("Afiação de Furtif E.K. (+5% Crítico)", 20, "ouro", "espada_aprimorada", lambda: setattr(self.jogador, 'ctco', self.jogador.ctco + 1))
        ]
        itens.append(("Sair", 0, None, None, None))
        state = [
            self.jogador.moedas['ouro'] / 100,
            self.jogador.moedas['prata'] / 100,
            self.jogador.moedas['bronze'] / 100,
            self.jogador.dano_base / 100,
            self.jogador.escudo_base / 100
        ]
        acao = self.neural_cidade.choose_action(state)
        if acao >= len(itens):
            acao = len(itens) - 1
        nome, custo, moeda, flag, efeito = itens[acao]
        if nome == "Sair":
            return 0
        sucesso = False
        recompensa = 0
        if moeda == 'ouro' and self.jogador.moedas['ouro'] >= custo and (flag is None or not getattr(self.jogador, flag, False)):
            self.jogador.moedas['ouro'] -= custo
            efeito()
            if flag:
                setattr(self.jogador, flag, True)
            sucesso = True
            recompensa = 2.0
        elif moeda == 'prata' and self.jogador.moedas['prata'] >= custo and (flag is None or not getattr(self.jogador, flag, False)):
            self.jogador.moedas['prata'] -= custo
            efeito()
            if flag:
                setattr(self.jogador, flag, True)
            sucesso = True
            recompensa = 2.0
        else:
            recompensa = -1.0
        self.db.log_compra("Ferreiro", nome, custo, moeda, sucesso, recompensa)
        return recompensa

