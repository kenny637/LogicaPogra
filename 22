class Combate:
    def __init__(self, jogador, inimigo, neural_combate, db):
        self.jogador = jogador
        self.inimigo = inimigo
        self.neural = neural_combate
        self.db = db
        self.turno = 0
        self.ultima_acao_jogador = 0
        self.resultado_combate = "em_andamento"

    def _calcular_dano(self, atacante, alvo, is_magia=False):
        if is_magia:
            dano_base = random.randint(int(atacante.dano_magia * 0.7), atacante.dano_magia)
        else:
            dano_base = random.randint(int(atacante.dano_base * 0.7), atacante.dano_base)

        if atacante == self.jogador and random.random() < self.jogador.critico + self.jogador.ctco * 0.05:
            dano_base = int(dano_base * 1.5)
            if VERBOSE: print("Crítico!")

        if alvo.defendendo:
            escudo = random.randint(int(alvo.escudo_base * 0.7), alvo.escudo_base)
            dano = max(dano_base - escudo, 0)
            if VERBOSE: print(f"{alvo.nome} defendeu, dano reduzido para {dano}.")
            return dano
        elif alvo.esquivando:
            if random.randint(1,20) >= 10:
                if VERBOSE: print(f"{alvo.nome} esquivou!")
                return 0
            else:
                if VERBOSE: print(f"{alvo.nome} falhou na esquiva!")
                return dano_base
        else:
            return dano_base

    def _executar_acao(self, acao, quem, alvo, is_jogador):
        resultado = {"dano": 0, "cura": 0, "mana": 0, "falhou": False, "morreu": False}

        if acao in (1,3,4):
            if not quem.gastar_estamina(quem.perda_estamina_base):
                if VERBOSE: print(f"{quem.nome} está sem estamina!")
                resultado["falhou"] = True
                return resultado

        if acao == 1:
            dano = self._calcular_dano(quem, alvo, False)
            alvo.aplicar_dano(dano)
            resultado["dano"] = dano
            if alvo.vida <= 0:
                resultado["morreu"] = True
        elif acao == 2:
            quem.defendendo = True
            if VERBOSE: print(f"{quem.nome} se defende.")
        elif acao == 3:
            quem.esquivando = True
            if VERBOSE: print(f"{quem.nome} tenta esquivar.")
        elif acao == 4:
            if quem.mana < 15:
                if VERBOSE: print(f"{quem.nome} não tem mana!")
                resultado["falhou"] = True
                return resultado
            quem.mana -= quem.perda_mana_base
            dano = self._calcular_dano(quem, alvo, True)
            alvo.aplicar_dano(dano)
            resultado["dano"] = dano
            if alvo.vida <= 0:
                resultado["morreu"] = True
        elif acao == 5:
            if is_jogador:
                if self.jogador.pocao_cura <= 0:
                    if VERBOSE: print("Sem poções de cura!")
                    resultado["falhou"] = True
                    return resultado
                self.jogador.pocao_cura -= 1
                cura = int(self.jogador.vida_max * (self.jogador.eficiencia_cura / 100))
                self.jogador.curar(cura)
                resultado["cura"] = cura
                if VERBOSE: print(f"{quem.nome} curou {cura} HP.")
            else:
                if quem.mana < 15:
                    if VERBOSE: print(f"{quem.nome} não tem mana para curar!")
                    resultado["falhou"] = True
                    return resultado
                quem.mana -= quem.perda_mana_base
                cura = int(quem.vida_max * (quem.eficiencia_cura / 100))
                quem.curar(cura)
                resultado["cura"] = cura
                if VERBOSE: print(f"{quem.nome} curou {cura} HP.")
        elif acao == 6:
            if is_jogador:
                if self.jogador.pocao_mana <= 0:
                    if VERBOSE: print("Sem poções de mana!")
                    resultado["falhou"] = True
                    return resultado
                self.jogador.pocao_mana -= 1
                mana_rec = int(self.jogador.mana_max * (self.jogador.eficiencia_mana / 100))
                self.jogador.recuperar_mana(mana_rec)
                resultado["mana"] = mana_rec
                if VERBOSE: print(f"{quem.nome} recuperou {mana_rec} MP.")
            else:
                if quem.mana < 15:
                    if VERBOSE: print(f"{quem.nome} não tem mana para recuperar mana?")
                    resultado["falhou"] = True
                    return resultado
                quem.mana -= quem.perda_mana_base
                mana_rec = int(quem.mana_max * (quem.eficiencia_mana / 100))
                quem.recuperar_mana(mana_rec)
                resultado["mana"] = mana_rec
                if VERBOSE: print(f"{quem.nome} recuperou {mana_rec} MP.")
        return resultado

    def _calcular_recompensa(self, acao, resultado):
        if resultado.get("falhou", False):
            return -2

        vida_j = self.jogador.vida / self.jogador.vida_max
        mana_j = self.jogador.mana / self.jogador.mana_max
        dano = resultado.get("dano", 0)

        if acao == 1:
            if resultado.get("morreu", False):
                return 0
            if dano > self.jogador.dano_base * 0.8:
                return 2
            elif dano > 0:
                return 1
            elif vida_j < 0.2:
                return -3
            else:
                return -1
        elif acao == 2:
            return 0.5
        elif acao == 3:
            return 0.5
        elif acao == 4:
            if resultado.get("morreu", False):
                return 0
            if dano > self.jogador.dano_magia * 0.8:
                return 3
            elif dano > 0:
                return 2
            else:
                return -2
        elif acao == 5:
            if vida_j < 0.3:
                return 3
            elif vida_j < 0.5:
                return 2
            elif vida_j > 0.8:
                return -2
            else:
                return 0
        elif acao == 6:
            if mana_j < 0.3:
                return 2
            elif mana_j < 0.6:
                return 1
            elif mana_j > 0.8:
                return -1
            else:
                return 0
        return 0

    def rodada(self):
        self.turno += 1
        if VERBOSE:
            print(f"\n{'='*20} Turno {self.turno} {'='*20}")
            print(f"{self.jogador.nome}: {self.jogador.vida}/{self.jogador.vida_max} HP, "
                  f"{self.jogador.mana}/{self.jogador.mana_max} MP, {self.jogador.estamina}/{self.jogador.estamina_max} STA")
            print(f"{self.inimigo.nome}: {self.inimigo.vida}/{self.inimigo.vida_max} HP, "
                  f"{self.inimigo.mana}/{self.inimigo.mana_max} MP, {self.inimigo.estamina}/{self.inimigo.estamina_max} STA")

        self.jogador.defendendo = False
        self.jogador.esquivando = False
        self.inimigo.defendendo = False
        self.inimigo.esquivando = False
        self.jogador.aplicar_buffs()

        state = [
            self.inimigo.vida / self.inimigo.vida_max,
            self.jogador.vida / self.jogador.vida_max,
            self.jogador.mana / self.jogador.mana_max,
            self.jogador.estamina / self.jogador.estamina_max,
            self.ultima_acao_jogador / 6.0
        ]
        acao_idx = self.neural.choose_action(state)
        acao_jogador = acao_idx + 1
        if VERBOSE: print(f"Jogador escolheu {self._nome_acao(acao_jogador)}")

        res_j = self._executar_acao(acao_jogador, self.jogador, self.inimigo, True)
        recompensa = self._calcular_recompensa(acao_jogador, res_j)
        self.neural.learn(recompensa)
        self.db.log_combate_acao(self.turno, state, acao_jogador, recompensa, self.resultado_combate)

        if res_j.get("morreu", False):
            if VERBOSE: print(f"{self.inimigo.nome} foi derrotado!")
            return "vitoria"

        acao_inimigo = self.inimigo.escolher_acao_ia(self.ultima_acao_jogador)
        if VERBOSE: print(f"Inimigo escolheu {self._nome_acao(acao_inimigo)}")
        self._executar_acao(acao_inimigo, self.inimigo, self.jogador, False)

        if self.jogador.vida <= 0:
            if VERBOSE: print("Você foi derrotado!")
            return "derrota"

        self.ultima_acao_jogador = acao_jogador
        return "continua"

    def _nome_acao(self, acao):
        nomes = {1:"Atacar",2:"Defender",3:"Esquivar",4:"Magia",5:"Curar",6:"Mana"}
        return nomes.get(acao, "?")

    def combater(self):
        while True:
            res = self.rodada()
            if res == "vitoria":
                self.resultado_combate = "vitoria"
                self.neural.end_episode()
                return True
            elif res == "derrota":
                self.resultado_combate = "derrota"
                self.neural.end_episode()
                return False
            # Não há sleep em modo silencioso para acelerar
            if VERBOSE:
                time.sleep(1)

