class gamer:
    def __init__(self,nome, nick):
        self.nome = nome 
        self.nick = nick
        self.favorito = list()

    def add_favoritos(self, game):
        self.favorito.append(game)

    def ficha(self):
        print(f'Jogador {self.nick}')
        print(f'Nome verdadeiro: {self.nome} ')
        print('Jogos favoritos')
        
        for i in range(len(self.favorito)):
            print(f'{self.favorito[i]}') 

